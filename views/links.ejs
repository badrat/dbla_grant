<!DOCTYPE html>
<html>
<head>
    <title><%= title || 'Links' %></title>
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta http-equiv="content-language" content="en-US" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google" content="notranslate">
    <meta name="thumbnail" content="/images/og_image_1200x630.png" />
    <meta property="og:image" content="/images/og_image_1200x630.png" />
    <meta property="og:title" content="<%= title || 'Links' %>" />
    <meta property="og:description" content="Films and Projects by Grant Alan Davis" />

    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="icon" href="<%= siteFavicon || '/images/og_image_1200x630.png' %>">
    <link rel="shortcut icon" href="<%= siteFavicon || '/images/og_image_1200x630.png' %>">
    <script src="/javascripts/lodash.min.js"></script>
    <script src="/javascripts/moment.min.js"></script>
    <script src="/javascripts/jquery-3.3.1.min.js"></script>
    <script src="/javascripts/site.js"></script>
</head>
<body>
    <%- include('_header') %>
    <div class="page-shell">
    <h1 class="projects-title">Links</h1>
    <div class="links-list-container">
    <% if (links && links.length) { %>
        <% links.forEach(function(linkItem) { %>
            <div class="links-list-item">
                <a class="links-list-link" href="<%= linkItem.link_url %>" target="_blank" rel="noopener noreferrer"><%= linkItem.link_name %></a>
            </div>
        <% }); %>
    <% } else { %>
    <p>Links and resources.</p>
    <% } %>
    </div>
    </div>
</body>
</html>
