<!DOCTYPE html>
<html>
<head>
    <title><%= title || 'Info' %></title>
    <meta http-equiv="content-type" content="text/html; charset=utf-8" />
    <meta http-equiv="content-language" content="en-US" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google" content="notranslate">
    <meta name="thumbnail" content="/images/og_image_1200x630.png" />
    <meta property="og:image" content="/images/og_image_1200x630.png" />
    <meta property="og:title" content="<%= title || 'Info' %>" />
    <meta property="og:description" content="Films and Projects by Grant Alan Davis" />

    <link rel='stylesheet' href='/stylesheets/style.css' />
    <script src="/javascripts/lodash.min.js"></script>
    <script src="/javascripts/moment.min.js"></script>
    <script src="/javascripts/jquery-3.3.1.min.js"></script>
    <script src="/javascripts/site.js"></script>
</head>
<body>
    <%- include('_header') %>
    <div class="page-shell">
    <h1><%= bio.title || 'Info' %></h1>
    <% if (bio.pic) { %>
    <img src="<%= bio.pic %>" alt="Bio Picture">
    <% } %>
    <div><%- bio.bio_html || bio.bio || '' %></div>
    <% if (contact && (contact.contact_html || contact.contact)) { %>
    <hr />
    <h2><%= contact.title || 'Contact' %></h2>
    <div><%- contact.contact_html || contact.contact %></div>
    <% } %>
    </div>
</body>
</html>